{
  "name": "translate-overlay",
  "version": "1.0.0",
  "description": "Game Translation Overlay using Electron & Tesseract OCR",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "test": "echo \"Error: no test specified\" && exit 1",
    "dist": "electron-builder"
  },
  "author": "Jane Doe",
  "license": "MIT",
  "build": {
    "appId": "com.tpk.translateoverlay",
    "directories": {
    "output": "dist"
  },
    "productName": "TranslateOverlay",
    "win": {
      "target": "portable",
      "icon": "TSO.ico"
    },
    "files": [
      "**/*",
      "!raw_shot.png",
      "!processed_shot.png",
      "!node_modules/*/{CHANGELOG.md,README.md,test,obj,bin}/*"
    ],
    "asar": true
  },
  "devDependencies": {
    "electron": "^23.1.3",
    "electron-builder": "^26.8.1"
  },
  "dependencies": {
    "screenshot-desktop": "^1.15.3",
    "sharp": "^0.34.5",
    "tesseract.js": "^7.0.0"
  }
}